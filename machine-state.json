{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/patrickdmw/datahub-schemas/refs/heads/main/machine-state.json",
  "allOf": [
    {
      "$ref": "https://raw.githubusercontent.com/patrickdmw/datahub-schemas/refs/heads/main/baseline.json"
    }
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "state"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "running",
            "idle",
            "error"
          ]
        },
        "errorReason": {
          "type": "string",
          "enum": [
            "stuck",
            "burning",
            "spinning"
          ]
        }
      }
    }
  }
}