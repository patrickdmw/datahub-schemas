{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/patrickdmw/datahub-schemas/refs/heads/main/combined.json",
  "$defs": {
    "point": {
      "title": "Longitude and Latitude",
      "description": "A geographical coordinate on a planet (most commonly Earth).",
      "type": "object",
      "required": ["latitude", "longitude"],
      "properties": {
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        }
      }
    },
    "baseline": {
      "type": "object",
      "required": ["uuid", "timestamp", "source", "data"],
      "additionalProperties": true,
      "properties": {
        "uuid": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "data": {
          "type": "object"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
        }
      }
    },
    "machine-location": {
      "properties": {
        "data": {
          "required": ["currentPosition"],
          "properties": {
            "currentPosition": {
              "$ref": "#/$defs/point"
            },
            "previousPosition": {
              "$ref": "#/$defs/point"
            }
          }
        }
      }
    },
    "machine-state": {
      "properties": {
        "data": {
          "type": "object",
          "required": ["state"],
          "properties": {
            "state": {
              "type": "string",
              "enum": ["running", "idle", "error"]
            },
            "errorReason": {
              "type": "string",
              "enum": ["stuck", "burning", "spinning"]
            }
          }
        }
      }
    },
    "parts-produced": {
      "properties": {
        "data": {
          "type": "object",
          "required": ["goodParts", "badParts"],
          "properties": {
            "goodParts": {
              "type": "number",
              "minimum": 0
            },
            "badParts": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    }
  },
  "allOf": [
    { "$ref": "#/$defs/baseline" },
    {
      "oneOf": [
        { "$ref": "#/$defs/machine-location" },
        { "$ref": "#/$defs/machine-state" },
        { "$ref": "#/$defs/parts-produced" }
      ]
    }
  ]
}
